# Prscope Environment Variables (sample)
# Copy to .env and fill in: cp env.sample .env
# Used when running prscope profile / prscope plan chat from this repo.

# GitHub (for upstream sync; optional if you only use plan chat)
GITHUB_TOKEN=github_pat_your_token_here

# LLM — prscope.yml uses gpt-4o and gpt-4o-mini by default (OpenAI only)
OPENAI_API_KEY=sk-your-openai-key

# Optional: only if you set a Claude model in prscope.yml planning section
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
